APP_NAME=Naija Sentiment Tracker API
APP_ENV=development
API_V1_PREFIX=/api

# --- Local Database Credentials ---
# Use the PG* fields for local development if you are not setting DATABASE_URL directly.
PGHOST=localhost
PGPORT=5432
PGDATABASE=naija_sentiment_tracker
PGUSER=postgres
PGPASSWORD=your_actual_password_here

# --- Database URL ---
# Local example:
# DATABASE_URL=postgresql+psycopg://postgres:your_actual_password_here@localhost:5432/naija_sentiment_tracker
#
# Azure example:
# DATABASE_URL=postgresql+psycopg://<azure_db_user>:<azure_db_password>@<azure_db_host>:5432/<azure_db_name>?sslmode=require
DATABASE_URL=

# --- Azure AI Language ---
AZURE_LANGUAGE_ENDPOINT=https://your-language-resource.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=your_azure_language_key
AZURE_LANGUAGE_DEFAULT_LANGUAGE=en
AZURE_LANGUAGE_BATCH_SIZE=10
AZURE_LANGUAGE_RETRY_ATTEMPTS=3
AZURE_LANGUAGE_RETRY_DELAY_SECONDS=2
AZURE_LANGUAGE_BATCH_SLEEP_SECONDS=1

# --- Ingestion ---
INGEST_BATCH_SIZE=10
CSV_SOURCE_PATH=./data/raw_macro_data.csv

# --- Frontend / CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Startup / Scheduler ---
AUTO_CREATE_SCHEMA_ON_STARTUP=false
SCHEDULER_ENABLED=false
SCHEDULER_DAILY_HOUR=6
SCHEDULER_INCLUDE_NEWS=true
SCHEDULER_NEWS_LIMIT=20
SCHEDULER_SKIP_NEWS_PAGES=true
