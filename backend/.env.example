APP_NAME=Naija Sentiment Tracker API
APP_ENV=development
API_V1_PREFIX=/api

# --- Database Credentials ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=naija_sentiment_tracker
PGUSER=postgres
PGPASSWORD=your_actual_password_here

# --- Corrected SQLAlchemy URL for Postgres ---
DATABASE_URL=postgresql://${PGUSER}:${PGPASSWORD}@${PGHOST}:${PGPORT}/${PGDATABASE}

# --- Azure & Data Config ---
AZURE_LANGUAGE_ENDPOINT=
AZURE_LANGUAGE_KEY=
INGEST_BATCH_SIZE=10
CSV_SOURCE_PATH=./data/raw_macro_data.csv
